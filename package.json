{
  "name": "actions-extension",
  "publisher": "aiday-marlen",
  "displayName": "actions-extension",
  "description": "Run custom VS Code command sequences from a dedicated Activity Bar view.",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/aiday-mar/actions-extension.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "actionsExtension",
          "title": "Action Sequences",
          "icon": "$(run-all)"
        }
      ]
    },
    "views": {
      "actionsExtension": [
        {
          "id": "actionsExtension.sequencesView",
          "name": "Sequences",
          "icon": "$(list-tree)"
        }
      ]
    },
    "commands": [
      {
        "command": "actionsExtension.runSequence",
        "title": "Run Sequence",
        "icon": "$(play)"
      },
      {
        "command": "actionsExtension.openSequencesSettings",
        "title": "Open Sequences Settings",
        "icon": "$(gear)"
      },
      {
        "command": "actionsExtension.refreshSequences",
        "title": "Refresh Sequences",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "actionsExtension.openSequencesSettings",
          "when": "view == actionsExtension.sequencesView",
          "group": "navigation"
        },
        {
          "command": "actionsExtension.refreshSequences",
          "when": "view == actionsExtension.sequencesView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "actionsExtension.runSequence",
          "when": "view == actionsExtension.sequencesView && viewItem == actionSequence",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Action Sequences",
      "properties": {
        "actionsExtension.sequences": {
          "type": "array",
          "default": [
            {
              "name": "Generate Commit Message & Commat",
              "commands": [
                "github.copilot.git.generateCommitMessage",
                "git.commitAll",
                "git.push"
              ]
            },
            {
              "name": "Reload Window",
              "commands": [
                "workbench.action.reloadWindow"
              ]
            },
            {
              "name": "Format & Save",
              "commands": [
                "editor.action.formatDocument",
                "workbench.action.files.save"
              ]
            }
          ],
          "description": "List of command sequences to show in the Action Sequences panel.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for this sequence."
              },
              "commands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "VS Code commands to run in order (e.g. workbench.action.files.save)."
              }
            },
            "required": [
              "name",
              "commands"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}